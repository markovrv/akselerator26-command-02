# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=forward_industry
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# LLM Configuration
# Provider: "openai-compatible" или "openrouter"
LLM_PROVIDER=openai-compatible

# OpenAI-compatible (любой OpenAI-совместимый провайдер)
LLM_API_KEY=your-api-key
LLM_API_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo

# OpenRouter (альтернативный вариант, используется если LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-3.5-turbo

# File Upload Configuration
MAX_FILE_SIZE=52428800
UPLOAD_PATH=./uploads

# S3 Storage (for 3D models and files)
S3_BUCKET=your-bucket-name
S3_REGION=your-region
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# n8n Webhook URL
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
